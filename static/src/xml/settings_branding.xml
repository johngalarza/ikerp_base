<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="ikerp_base.res_config_edition_inherit"
       t-inherit="res_config_edition"
       t-inherit-mode="extension">
        <xpath expr="//h3" position="replace">
            <h3 class="px-0">
                IKERP <t t-esc="serverVersion"/>
            </h3>
        </xpath>
        <xpath expr="//small" position="replace">
            <small>Copyright © IKERP — <a id="license" target="_blank" href="http://www.gnu.org/licenses/lgpl.html" style="text-decoration: underline;">GNU LGPL Licensed</a></small>
        </xpath>
    </t>

    <t t-name="ikerp_base.UpgradeDialog_inherit"
       t-inherit="web.UpgradeDialog"
       t-inherit-mode="extension">
        <xpath expr="//Dialog" position="attributes">
            <attribute name="title.translate">IKERP Enterprise</attribute>
        </xpath>
        <xpath expr="//div[hasclass('w-100') and hasclass('w-md-50')][1]" position="replace">
            <div class="w-100 w-md-50">
                Get this feature and much more with IKERP Enterprise!
                <ul class="list-unstyled">
                    <li><i class="fa fa-check"/> Access to all Enterprise Apps</li>
                    <li><i class="fa fa-check"/> New design</li>
                    <li><i class="fa fa-check"/> Mobile support</li>
                    <li><i class="fa fa-check"/> Upgrade to future versions</li>
                    <li><i class="fa fa-check"/> Bugfixes guarantee</li>
                </ul>
            </div>
        </xpath>
    </t>

</templates>
